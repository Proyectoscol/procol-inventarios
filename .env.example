# Copia a .env.local y completa los valores:
#   cp .env.example .env.local

# --- Base de datos (obligatorio) ---
#
# Easypanel: el panel muestra "Internal Connection URL" con host tipo inventaria_postgres.
# Eso es correcto DENTRO del servidor (contenedores en la misma red). Desde tu Mac NO funciona.
#
# Para desarrollo local elige una de estas:
# - Postgres en localhost (DATABASE_URL con host localhost).
# - Si Easypanel expone Postgres al exterior: usa el dominio/IP público y el puerto mapeado
#   (no inventaria_postgres).
# - Túnel SSH al VPS y luego DATABASE_URL=...@127.0.0.1:PUERTO_LOCAL/...
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# En el SERVIDOR Easypanel (variables del app service), sí puedes usar POSTGRES_HOST=inventaria_postgres
# o la Internal URL; build-db-url.js arma DATABASE_URL al instalar:
# POSTGRES_USERNAME=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=

# --- NextAuth (obligatorio) ---
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# --- Opcional: cifrado ---
# ENCRYPTION_KEY=

# --- Email (Mailgun); opcional en local ---
# MAILGUN_DOMAIN=
# SMTP_PASS=
# SMTP_ADMIN_EMAIL=
# SMTP_SENDER_NAME=

# --- No pongas NODE_ENV aquí en desarrollo local ---
# (Los scripts npm ya fijan development/production; si lo defines, puede dar problemas con Next.js.)
